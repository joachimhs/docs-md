{
  "name": "@joachimhskeie/docsmd",
  "version": "0.1.1",
  "description": "Git-native documentation system with web UI and AI agent support",
  "private": false,
  "bin": {
    "docsmd": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "build/",
    "templates/",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "documentation",
    "git",
    "markdown",
    "wiki",
    "sveltekit",
    "ai",
    "adr"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "npm run build:web && npm run build:cli",
    "build:web": "vite build",
    "build:cli": "tsup cli/index.ts --format esm --out-dir dist/cli --target node20 --shims --external commander --external chalk --external open --external gray-matter --external flexsearch --external simple-git --external js-yaml",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@milkdown/crepe": "^7.19.2",
    "@milkdown/kit": "^7.19.2",
    "@shikijs/rehype": "^1.29.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "commander": "^14.0.3",
    "diff2html": "^3.4.56",
    "flexsearch": "^0.7.43",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "open": "^11.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "remark-stringify": "^11.0.0",
    "shiki": "^1.29.2",
    "simple-git": "^3.33.0",
    "strip-markdown": "^6.0.0",
    "unified": "^11.0.5"
  },
  "type": "module"
}
